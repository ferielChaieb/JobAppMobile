<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvJobTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senior Developer"
            android:textStyle="bold"
            android:textColor="#111827"
            android:textSize="16sp"/>

        <!-- Meta -->
        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full-time • New York"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:layout_marginTop="6dp"/>

        <!-- Status + Edit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active"
                android:textColor="#16A34A"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#6D28D9"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>
        </LinearLayout>

        <!-- Detail button (style like your example) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="Detail Job"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="#F3E8FF"
            android:textColor="#6D28D9"
            app:cornerRadius="12dp"
            app:strokeColor="#E9D5FF"
            app:strokeWidth="1dp"

           />
    </LinearLayout>

</androidx.cardview.widget.CardView>
