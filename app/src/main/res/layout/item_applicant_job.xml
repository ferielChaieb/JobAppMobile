<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Titre + statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvJobTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UI / UX Designer"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tvStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_chip_green" />
        </LinearLayout>

        <!-- Société + localisation -->
        <TextView
            android:id="@+id/tvCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Company name"
            android:textColor="#444444"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tunis, Tunisia"
            android:textColor="#777777"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <!-- Infos bas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvApplicantsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 applicants"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:background="@drawable/bg_chip_light_blue"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvPostedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Published recently"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginStart="8dp" />

        </LinearLayout>
        <!-- Ligne actions en bas de la carte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp">

            <!-- … ton badge Active / tes autres vues à gauche … -->

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Bouton supprimer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteOffer"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Delete"
                android:textAllCaps="false"
                android:textSize="11sp"
                app:cornerRadius="16dp"
                app:backgroundTint="#E53935"
                android:textColor="@android:color/white" />
        </LinearLayout>


    </LinearLayout>


</com.google.android.material.card.MaterialCardView>
